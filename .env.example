TELEGRAM_BOT_TOKEN=your_bot_token_here
# Optional: channel id (username like @channel or numeric chat id)
CHANNEL_ID=@your_channel_or_id
# Optional: run the Space as an always-on scheduler
ENABLE_SCHEDULER=true
# Optional: listen for /start and group/channel add events to register destinations
ENABLE_TELEGRAM_LISTENER=true
# Optional: 24h time for the daily post in BOT_TIMEZONE
DAILY_POST_TIME=06:00
# Optional: article limit and timezone overrides
NEWS_LIMIT=5
BOT_TIMEZONE=Africa/Addis_Ababa
# Optional: where the bot stores discovered Telegram destinations
TELEGRAM_TARGETS_FILE=telegram_targets.json
# Optional: Telegram Bot API base URL. Point this at a proxy (e.g. a Cloudflare
# Worker) on hosts that block api.telegram.org, such as Hugging Face Spaces.
# TELEGRAM_API_BASE=https://your-worker.your-subdomain.workers.dev
